{
  "name": "@vgc/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm --workspace @vgc/explanations run build && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:smoke-test": "tsx src/db/smoke-test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"Add linter in Phase 0.1\""
  },
  "dependencies": {
    "@vgc/explanations": "file:../../packages/explanations",
    "express": "^4.22.1",
    "pg": "8.15.6"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "22.15.3",
    "@types/pg": "8.15.3",
    "tsx": "4.19.3",
    "typescript": "5.8.3"
  }
}
